<script>
// ═══════════════════════════════════════════════════
//  ASSETS CONFIG
// ═══════════════════════════════════════════════════
const ASSETS = [
  { id: 'petr4',  symbol: 'PETR4',  name: 'PETR4',  type: 'stock',  currency: 'R$',  tvSymbol: 'BMFBOVESPA:PETR4'  },
  { id: 'vale3',  symbol: 'VALE3',  name: 'VALE3',  type: 'stock',  currency: 'R$',  tvSymbol: 'BMFBOVESPA:VALE3'  },
  { id: 'itub4',  symbol: 'ITUB4',  name: 'ITUB4',  type: 'stock',  currency: 'R$',  tvSymbol: 'BMFBOVESPA:ITUB4'  },
  { id: 'sapr11', symbol: 'SAPR11', name: 'SAPR11', type: 'stock',  currency: 'R$',  tvSymbol: 'BMFBOVESPA:SAPR11' },
  { id: 'gold',   symbol: 'GC=F',   name: 'OURO',   type: 'stock',  currency: 'US$', tvSymbol: 'OANDA:XAUUSD'      },
  { id: 'oil',    symbol: 'BZ=F',   name: 'BRENT',  type: 'stock',  currency: 'US$', tvSymbol: 'OANDA:BCOUSD'      },
];

// Estado dos alertas: armazena se já foi disparado (cooldown de 30min)
const alertCooldown  = {};
const currentPrices  = {};
const previousPrices = {};

// ═══════════════════════════════════════════════════
//  TRADINGVIEW WIDGETS
// ═══════════════════════════════════════════════════
function createWidget(containerId, symbol) {
  new TradingView.widget({
    autosize: true,
    symbol: symbol,
    interval: "5",
    timezone: "America/Sao_Paulo",
    theme: "dark",
    style: "3",
    locale: "br",
    hide_top_toolbar: false,
    hide_legend: false,
    container_id: containerId
  });
}

ASSETS.forEach(a => createWidget(`tv_${a.id}`, a.tvSymbol));

// ── EmailJS init ─────────────────────────────────────
emailjs.init('5PeL0XiF7y9agfS_v');

// ═══════════════════════════════════════════════════
//  CLOCK
// ═══════════════════════════════════════════════════
function updateClock() {
  const now = new Date();
  document.getElementById('clock').textContent =
    now.toLocaleTimeString('pt-BR', { hour12: false });
}
setInterval(updateClock, 1000);
updateClock();

// ═══════════════════════════════════════════════════
//  PRICE FETCHING — brapi.dev
// ═══════════════════════════════════════════════════
async function fetchPrices() {
  const stocks = ASSETS.map(a => a.symbol).join(',');
  try {
    const res  = await fetch(`https://brapi.dev/api/quote/${stocks}`);
    const data = await res.json();
    if (!data.results) return;

    data.results.forEach(q => {
      const asset = ASSETS.find(a => a.symbol === q.symbol);
      if (!asset) return;

      const prev = currentPrices[asset.id];
      if (prev !== undefined) previousPrices[asset.id] = prev;
      currentPrices[asset.id] = q.regularMarketPrice;

      updatePriceUI(asset, q);
      checkAlerts(asset, q.regularMarketPrice);
    });
  } catch (e) {
    console.warn('Erro ao buscar preços:', e);
  }
}

// ═══════════════════════════════════════════════════
//  UPDATE UI
// ═══════════════════════════════════════════════════
function updatePriceUI(asset, q) {
  const price  = q.regularMarketPrice;
  const change = q.regularMarketChangePercent;
  const cur    = asset.currency;

  // Preço
  const el = document.getElementById(`price-${asset.id}`);
  if (el) el.textContent = `${cur} ${price.toFixed(2)}`;

  // Variação
  const chEl = document.getElementById(`change-${asset.id}`);
  if (chEl) {
    const sign = change >= 0 ? '+' : '';
    chEl.textContent = `${sign}${change.toFixed(2)}%`;
    chEl.className = `price-change ${change > 0 ? 'up' : change < 0 ? 'down' : 'flat'}`;
  }

  // Atualiza status do dot se alerta estiver definido
  updateAlertStatus(asset.id);
}

// ═══════════════════════════════════════════════════
//  ALERT STATUS UI
// ═══════════════════════════════════════════════════
function updateAlertStatus(id) {
  const minVal = parseFloat(document.getElementById(`min-${id}`)?.value);
  const maxVal = parseFloat(document.getElementById(`max-${id}`)?.value);
  const price  = currentPrices[id];
  const dot    = document.getElementById(`dot-${id}`);
  const txt    = document.getElementById(`status-${id}`);
  const card   = document.getElementById(`card-${id}`);
  const minInput = document.getElementById(`min-${id}`);
  const maxInput = document.getElementById(`max-${id}`);

  if (!dot || !txt) return;

  const hasMin = !isNaN(minVal) && minVal > 0;
  const hasMax = !isNaN(maxVal) && maxVal > 0;

  card.classList.remove('alert-min', 'alert-max');
  minInput.classList.remove('triggered-min');
  maxInput.classList.remove('triggered-max');

  if (!hasMin && !hasMax) {
    dot.className = 'status-dot';
    txt.textContent = 'SEM ALERTA';
    return;
  }

  if (price !== undefined) {
    if (hasMin && price <= minVal) {
      dot.className = 'status-dot hit-min';
      txt.textContent = '▲ MÍN ATINGIDO';
      card.classList.add('alert-min');
      minInput.classList.add('triggered-min');
      return;
    }
    if (hasMax && price >= maxVal) {
      dot.className = 'status-dot hit-max';
      txt.textContent = '▼ MÁX ATINGIDO';
      card.classList.add('alert-max');
      maxInput.classList.add('triggered-max');
      return;
    }
  }

  dot.className = 'status-dot active';
  txt.textContent = 'MONITORANDO';
}

// ═══════════════════════════════════════════════════
//  ALERT CHECK + NOTIFICATIONS
// ═══════════════════════════════════════════════════
function checkAlerts(asset, price) {
  const minVal = parseFloat(document.getElementById(`min-${asset.id}`)?.value);
  const maxVal = parseFloat(document.getElementById(`max-${asset.id}`)?.value);

  const now = Date.now();
  const cooldown = 30 * 60 * 1000; // 30 minutos

  if (!isNaN(minVal) && minVal > 0 && price <= minVal) {
    const key = `${asset.id}_min`;
    if (!alertCooldown[key] || now - alertCooldown[key] > cooldown) {
      alertCooldown[key] = now;
      const msg = `🟢 ALERTA TRADER PRO\n${asset.name} atingiu o preço MÍNIMO\nPreço atual: ${asset.currency} ${price.toFixed(2)}\nMínimo definido: ${asset.currency} ${minVal.toFixed(2)}`;
      sendNotifications(asset, msg, 'min');
    }
  }

  if (!isNaN(maxVal) && maxVal > 0 && price >= maxVal) {
    const key = `${asset.id}_max`;
    if (!alertCooldown[key] || now - alertCooldown[key] > cooldown) {
      alertCooldown[key] = now;
      const msg = `🔴 ALERTA TRADER PRO\n${asset.name} atingiu o preço MÁXIMO\nPreço atual: ${asset.currency} ${price.toFixed(2)}\nMáximo definido: ${asset.currency} ${maxVal.toFixed(2)}`;
      sendNotifications(asset, msg, 'max');
    }
  }
}

