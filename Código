// ═══════════════════════════════════════════════════
//  SETTINGS MODAL
// ═══════════════════════════════════════════════════
function loadConfig() {
  try { return JSON.parse(localStorage.getItem('traderCfg') || '{}'); }
  catch { return {}; }
}

function saveConfig(cfg) {
  localStorage.setItem('traderCfg', JSON.stringify(cfg));
}

function openSettings() {
  const cfg = loadConfig();
  document.getElementById('wpp-phone').value  = cfg.wppPhone  || '';
  document.getElementById('wpp-apikey').value = cfg.wppApikey || '';
  document.getElementById('email-addr').value = cfg.email     || '';
  document.getElementById('modal').classList.add('open');
}

function closeSettings() {
  document.getElementById('modal').classList.remove('open');
}

function saveSettings() {
  const cfg = {
    wppPhone:  document.getElementById('wpp-phone').value.trim(),
    wppApikey: document.getElementById('wpp-apikey').value.trim(),
    email:     document.getElementById('email-addr').value.trim(),
  };
  saveConfig(cfg);
  closeSettings();

  // Pede permissão de notificação do navegador
  if (Notification.permission === 'default') {
    Notification.requestPermission();
  }

  const channels = [];
  if (cfg.wppPhone && cfg.wppApikey) channels.push('WhatsApp');
  if (cfg.email) channels.push('E-mail');
  toast(`✅ Alertas ativados via ${channels.join(' + ') || 'nenhum canal'}.`, 'success');
}

// Fecha modal clicando fora
document.getElementById('modal').addEventListener('click', function(e) {
  if (e.target === this) closeSettings();
});

// ═══════════════════════════════════════════════════
//  TOAST
// ═══════════════════════════════════════════════════
function toast(msg, type = 'success') {
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  el.textContent = msg;
  document.getElementById('toast-container').appendChild(el);
  setTimeout(() => el.remove(), 5000);
}

