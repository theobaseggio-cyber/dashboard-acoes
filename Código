<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>Trader Pro — Théo Baseggio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">

  <style>
    :root {
      --bg:        #080b0f;
      --panel:     #0d1117;
      --border:    #1c2430;
      --green:     #00e676;
      --red:       #ff3d57;
      --yellow:    #ffd600;
      --blue:      #00b0ff;
      --muted:     #4a5568;
      --text:      #c9d1d9;
      --mono:      'Share Tech Mono', monospace;
      --ui:        'Rajdhani', sans-serif;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--ui);
      height: 100vh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* ── HEADER ─────────────────────────────────────── */
    header {
      background: var(--panel);
      border-bottom: 1px solid var(--border);
      padding: 0 20px;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
    }

    .header-left {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .header-logo {
      font-family: var(--mono);
      font-size: 13px;
      color: var(--blue);
      letter-spacing: 1px;
    }

    .header-title {
      font-size: 16px;
      font-weight: 700;
      letter-spacing: 2px;
      color: #fff;
    }

    .header-right {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    #clock {
      font-family: var(--mono);
      font-size: 13px;
      color: var(--muted);
    }

    .btn-settings {
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text);
      font-family: var(--ui);
      font-size: 13px;
      font-weight: 600;
      padding: 5px 14px;
      border-radius: 4px;
      cursor: pointer;
      letter-spacing: 1px;
      transition: all 0.2s;
    }
    .btn-settings:hover {
      border-color: var(--blue);
      color: var(--blue);
    }

    .alert-badge {
      background: var(--red);
      color: #fff;
      font-family: var(--mono);
      font-size: 10px;
      padding: 2px 7px;
      border-radius: 10px;
      display: none;
    }
    .alert-badge.visible { display: inline-block; }

    /* ── GRID ────────────────────────────────────────── */
    .grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      grid-template-rows: 1fr 1fr;
      gap: 6px;
      padding: 6px;
      flex: 1;
      min-height: 0;
    }

    .card {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 6px;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      transition: border-color 0.3s;
      position: relative;
    }
    .card.alert-min { border-color: var(--green); box-shadow: 0 0 12px rgba(0,230,118,0.15); }
    .card.alert-max { border-color: var(--red);   box-shadow: 0 0 12px rgba(255,61,87,0.15); }

    .chart-wrap {
      flex: 1;
      min-height: 0;
      position: relative;
    }

    /* ── PRICE PANEL ─────────────────────────────────── */
    .price-panel {
      background: #0a0e14;
      border-top: 1px solid var(--border);
      padding: 7px 12px;
      display: flex;
      align-items: center;
      gap: 12px;
      flex-shrink: 0;
    }

    .price-left {
      display: flex;
      flex-direction: column;
      min-width: 110px;
    }

    .asset-name {
      font-size: 11px;
      color: var(--muted);
      font-weight: 600;
      letter-spacing: 1px;
    }

    .price-value {
      font-family: var(--mono);
      font-size: 18px;
      color: #fff;
      line-height: 1;
    }

    .price-change {
      font-family: var(--mono);
      font-size: 11px;
    }
    .price-change.up   { color: var(--green); }
    .price-change.down { color: var(--red); }
    .price-change.flat { color: var(--muted); }

    .divider {
      width: 1px;
      height: 36px;
      background: var(--border);
      flex-shrink: 0;
    }

    .alert-inputs {
      display: flex;
      gap: 8px;
      align-items: center;
      flex: 1;
    }

    .input-group {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .input-label {
      font-size: 9px;
      letter-spacing: 1px;
      font-weight: 700;
    }
    .input-label.min { color: var(--green); }
    .input-label.max { color: var(--red); }

    .price-input {
      background: #111820;
      border: 1px solid var(--border);
      color: var(--text);
      font-family: var(--mono);
      font-size: 13px;
      padding: 3px 7px;
      border-radius: 3px;
      width: 90px;
      transition: border-color 0.2s;
    }
    .price-input:focus { outline: none; border-color: var(--blue); }
    .price-input.triggered-min { border-color: var(--green); color: var(--green); }
    .price-input.triggered-max { border-color: var(--red);   color: var(--red); }

    .alert-status {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2px;
      min-width: 70px;
    }

    .status-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--muted);
      transition: all 0.3s;
    }
    .status-dot.active   { background: var(--yellow); box-shadow: 0 0 6px var(--yellow); animation: pulse 1.5s infinite; }
    .status-dot.hit-min  { background: var(--green);  box-shadow: 0 0 8px var(--green); }
    .status-dot.hit-max  { background: var(--red);    box-shadow: 0 0 8px var(--red); }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.4; }
    }

    .status-text {
      font-family: var(--mono);
      font-size: 9px;
      color: var(--muted);
      text-align: center;
      letter-spacing: 0.5px;
    }

    /* ── MODAL ───────────────────────────────────────── */
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.8);
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s;
    }
    .modal-overlay.open { opacity: 1; pointer-events: all; }

    .modal {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 8px;
      width: 480px;
      max-width: 95vw;
      padding: 28px;
    }

    .modal-title {
      font-size: 18px;
      font-weight: 700;
      letter-spacing: 2px;
      color: #fff;
      margin-bottom: 6px;
    }

    .modal-sub {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 24px;
      line-height: 1.5;
    }

    .modal-sub a { color: var(--blue); }

    .form-group { margin-bottom: 16px; }

    .form-label {
      display: block;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1px;
      color: var(--muted);
      margin-bottom: 6px;
    }

    .form-input {
      width: 100%;
      background: #111820;
      border: 1px solid var(--border);
      color: #fff;
      font-family: var(--mono);
      font-size: 14px;
      padding: 9px 12px;
      border-radius: 4px;
      transition: border-color 0.2s;
    }
    .form-input:focus { outline: none; border-color: var(--blue); }

    .form-hint {
      font-size: 11px;
      color: var(--muted);
      margin-top: 4px;
    }

    .modal-footer {
      display: flex;
      gap: 10px;
      margin-top: 24px;
    }

    .btn-save {
      flex: 1;
      background: var(--blue);
      color: #000;
      border: none;
      font-family: var(--ui);
      font-size: 13px;
      font-weight: 700;
      padding: 10px;
      border-radius: 4px;
      cursor: pointer;
      letter-spacing: 1px;
      transition: opacity 0.2s;
    }
    .btn-save:hover { opacity: 0.85; }

    .btn-cancel {
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text);
      font-family: var(--ui);
      font-size: 13px;
      font-weight: 600;
      padding: 10px 20px;
      border-radius: 4px;
      cursor: pointer;
      transition: border-color 0.2s;
    }
    .btn-cancel:hover { border-color: var(--muted); }

    .section-tag {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 2px;
      color: var(--muted);
      border-bottom: 1px solid var(--border);
      padding-bottom: 8px;
      margin-bottom: 14px;
      margin-top: 20px;
    }

    /* ── TOAST ───────────────────────────────────────── */
    #toast-container {
      position: fixed;
      bottom: 20px;
      right: 20px;
      z-index: 2000;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .toast {
      background: #1a2233;
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 12px 16px;
      font-size: 13px;
      max-width: 300px;
      animation: slideIn 0.3s ease;
    }
    .toast.success { border-left: 3px solid var(--green); }
    .toast.warning { border-left: 3px solid var(--yellow); }
    .toast.error   { border-left: 3px solid var(--red); }

    @keyframes slideIn {
      from { transform: translateX(20px); opacity: 0; }
      to   { transform: translateX(0);    opacity: 1; }
    }
  </style>
</head>
